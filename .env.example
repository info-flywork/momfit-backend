PORT=3000

# Bunny CDN — statik medya (resim, video)
CDN_BASE_URL=
CDN_STORAGE_ZONE=
CDN_STORAGE_API_KEY=your_bunny_storage_api_key
CDN_ENABLED=true
CDN_MAX_WEEK_ANIMAL=41

DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=your_password_here

# Firebase Admin — Project settings → Service accounts → Generate new private key
# Dosyayı backend/ klasörüne koyun. Örnek isimler:
#   ./firebase-service-account.json
#   ./momfit-90af3-firebase-adminsdk-xxxxx.json
# Boş bırakılırsa backend/ içindeki *firebase-adminsdk*.json otomatik aranır.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# OpenAI — AI Chat için (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# RevenueCat Webhooks — Dashboard → Integrations → Webhooks
# Authorization header değerini birebir buraya koyun (örn: Bearer secret_xxx)
# Endpoint: POST /api/webhooks/revenuecat
REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer your_revenuecat_webhook_secret
